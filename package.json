{
  "name": "mirador-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "check": "bash scripts/pre-push-checks.sh --standard",
    "check:quick": "bash scripts/pre-push-checks.sh --quick",
    "check:full": "bash scripts/pre-push-checks.sh --full",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.html\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"src/**/*.html\" --fix",
    "lint:sarif": "eslint \"src/**/*.ts\" \"src/**/*.html\" --format @microsoft/eslint-formatter-sarif --output-file eslint-report.sarif || true",
    "compodoc": "compodoc --config config/.compodocrc.json",
    "compodoc:serve": "compodoc --config config/.compodocrc.json -s",
    "typedoc": "typedoc --options config/typedoc.json",
    "sonar": "sonar-scan -Dproject.settings=config/sonar-project.properties",
    "e2e": "playwright test --grep @golden",
    "e2e:ui": "playwright test --grep @golden --ui",
    "e2e:install": "playwright install chromium",
    "e2e:local": "E2E_BASE_URL=http://localhost:4200 playwright test --grep @golden",
    "e2e:demo": "bin/record-demo.sh",
    "e2e:visual": "E2E_BASE_URL=http://localhost:4200 playwright test --grep @visual",
    "e2e:visual:update": "E2E_BASE_URL=http://localhost:4200 playwright test --grep @visual --update-snapshots",
    "e2e:a11y": "playwright test --grep @a11y",
    "e2e:a11y:local": "E2E_BASE_URL=http://localhost:4200 playwright test --grep @a11y",
    "prepare": "cp scripts/pre-push-checks.sh .git/hooks/pre-push 2>/dev/null; chmod +x .git/hooks/pre-push 2>/dev/null || true"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@auth0/auth0-angular": "^2.8.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone": "^2.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/instrumentation-fetch": "^0.215.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-web": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@axe-core/playwright": "^4.11.2",
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^9.39.4",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@playwright/test": "^1.59.1",
    "@sonar/scan": "^4.3.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.3",
    "typedoc": "^0.28.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  },
  "//-overrides": "Force @compodoc/compodoc's pinned @angular-devkit subtree to 21.2.7 (was 21.1.0). Closes 5 npm audit CVEs (1 HIGH picomatch ReDoS + 1 MODERATE picomatch + 1 MODERATE ajv + 2 transitive devkit) without bumping compodoc itself (1.2.1 is the latest). Revisit when @compodoc/compodoc > 1.2.1 ships with a newer @angular-devkit pin — at that point this override may become a no-op and can be removed.",
  "overrides": {
    "@compodoc/compodoc": {
      "@angular-devkit/core": "21.2.7",
      "@angular-devkit/schematics": "21.2.7"
    }
  }
}
