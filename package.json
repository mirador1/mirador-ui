{
  "name": "mirador-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "check": "bash scripts/pre-push-checks.sh --standard",
    "check:quick": "bash scripts/pre-push-checks.sh --quick",
    "check:full": "bash scripts/pre-push-checks.sh --full",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "compodoc": "compodoc --config config/.compodocrc.json",
    "compodoc:serve": "compodoc --config config/.compodocrc.json -s",
    "typedoc": "typedoc --options config/typedoc.json",
    "sonar": "sonar-scanner",
    "prepare": "cp scripts/pre-push-checks.sh .git/hooks/pre-push 2>/dev/null; chmod +x .git/hooks/pre-push 2>/dev/null || true"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@auth0/auth0-angular": "^2.8.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@compodoc/compodoc": "^1.2.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sonar-scanner": "^3.1.0",
    "typedoc": "^0.28.19",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
